---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  type?: string;
}

const {
  title = '不標準答案',
  description: rawDesc = '老查與阿分的 Podcast。每週一集，在日常觀察裡找破框的角度。',
  ogImage,
  type = 'website',
} = Astro.props;

const description = rawDesc.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim().slice(0, 160);

const fullTitle = title === '不標準答案' ? title : `${title} — 不標準答案`;
---

<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={Astro.url.href} />

  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={Astro.url.href} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />

  <link rel="alternate" type="application/rss+xml" title="不標準答案" href="https://feed.firstory.me/rss/user/cmi76pcj000h7010chgezh8bs" />
  <meta name="google-site-verification" content="_smPOOXwZ5fzlRGZgFaObXqfLbgezY4Rz7AWZWsGKyM" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;700;900&display=swap" rel="stylesheet">
</head>
<body>
  <!-- Page transition loader -->
  <div id="page-loader" aria-hidden="true">
    <div class="loader-bar"></div>
    <div class="loader-glow"></div>
  </div>

  <style>
    #page-loader {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: #0F0235;
      pointer-events: none;
      animation: loader-fade 0.5s ease 1.0s forwards;
    }

    @keyframes loader-fade {
      0%   { opacity: 1; }
      100% { opacity: 0; visibility: hidden; }
    }

    .loader-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 3px;
      width: 0%;
      background: linear-gradient(90deg, #EE359E, #815BDB);
      box-shadow: 0 0 12px rgba(238,53,158,0.8), 0 0 24px rgba(129,91,219,0.4);
      animation: bar-fill 0.85s cubic-bezier(0.4, 0, 0.2, 1) 0.05s forwards;
    }

    @keyframes bar-fill {
      0%   { width: 0%; }
      60%  { width: 75%; }
      100% { width: 100%; }
    }

    .loader-glow {
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 300px;
      height: 80px;
      background: radial-gradient(ellipse at bottom, rgba(238,53,158,0.25) 0%, transparent 70%);
      animation: glow-pulse 0.85s ease 0.05s forwards;
      opacity: 0;
    }

    @keyframes glow-pulse {
      0%   { opacity: 0; }
      50%  { opacity: 1; }
      100% { opacity: 0.6; }
    }
  </style>

  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="site-logo">不標準答案</a>
      <nav class="header-nav">
        <a href="/">首頁</a>
        <a href="/#about">關於</a>
        <a href="/episodes">集數</a>
        <a href="/blog">網誌</a>
        <a href="/videos">影音</a>
        <a href="/contact">聯絡</a>
        <a href="https://open.firstory.me/user/cmi76pcj000h7010chgezh8bs" target="_blank" rel="noopener">訂閱</a>
      </nav>
      <div class="header-social">
        <a href="https://www.facebook.com/beyond.ans" target="_blank" rel="noopener" aria-label="Facebook">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://www.instagram.com/another20251021/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://www.youtube.com/@beyondanswersTW" target="_blank" rel="noopener" aria-label="YouTube">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/></svg>
        </a>
      </div>
    </div>
  </header>

  <slot />

  <!-- Floating mic button -->
  <a href="https://open.firstory.me/user/cmi76pcj000h7010chgezh8bs" target="_blank" rel="noopener" class="mic-fab" aria-label="收聽 Podcast">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
      <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
      <line x1="12" y1="19" x2="12" y2="23"/>
      <line x1="8" y1="23" x2="16" y2="23"/>
    </svg>
  </a>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-col">
        <h4 class="footer-heading">頁面</h4>
        <ul>
          <li><a href="/">首頁</a></li>
          <li><a href="/episodes">集數</a></li>
          <li><a href="/blog">網誌</a></li>
          <li><a href="/videos">影音</a></li>
          <li><a href="/#about">關於節目</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4 class="footer-heading">訂閱平台</h4>
        <ul>
          <li><a href="https://open.firstory.me/user/cmi76pcj000h7010chgezh8bs" target="_blank" rel="noopener">Firstory</a></li>
          <li><a href="#" target="_blank" rel="noopener">Apple Podcasts</a></li>
          <li><a href="#" target="_blank" rel="noopener">Spotify</a></li>
          <li><a href="https://feed.firstory.me/rss/user/cmi76pcj000h7010chgezh8bs" target="_blank" rel="noopener">RSS</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4 class="footer-heading">跟著我們</h4>
        <ul>
          <li><a href="https://www.facebook.com/beyond.ans" target="_blank" rel="noopener">Facebook</a></li>
          <li><a href="https://www.instagram.com/another20251021/" target="_blank" rel="noopener">Instagram</a></li>
          <li><a href="https://www.youtube.com/@beyondanswersTW" target="_blank" rel="noopener">YouTube</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>不標準答案 © {new Date().getFullYear()} All rights reserved.</span>
    </div>
  </footer>

  <style>
    /* ── HEADER ── */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(21, 8, 58, 0.92);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 2rem;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
    }

    .site-logo {
      font-family: 'Noto Sans', sans-serif;
      font-weight: 900;
      font-size: 1.05rem;
      color: #fff;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .header-nav {
      display: flex;
      align-items: center;
      gap: 1.8rem;
      flex: 1;
      justify-content: center;
    }

    .header-nav a {
      font-family: 'Noto Sans', sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      color: rgba(202, 192, 228, 0.8);
      transition: color 0.2s;
      white-space: nowrap;
    }

    .header-nav a:hover { color: #fff; }

    .header-social {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-shrink: 0;
    }

    .header-social a {
      color: rgba(202, 192, 228, 0.7);
      transition: color 0.2s;
      display: flex;
      align-items: center;
    }

    .header-social a:hover { color: #EE359E; }

    /* ── MIC FAB ── */
    .mic-fab {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      z-index: 40;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: #EE359E;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 20px rgba(238, 53, 158, 0.5);
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .mic-fab:hover {
      transform: scale(1.08);
      box-shadow: 0 6px 28px rgba(238, 53, 158, 0.7);
    }

    /* ── FOOTER ── */
    .site-footer {
      background: var(--surface);
      border-top: 1px solid var(--rule);
      padding-top: 4rem;
    }

    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 2rem 3rem;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }

    .footer-heading {
      font-family: 'Noto Sans', sans-serif;
      font-weight: 900;
      font-size: 0.85rem;
      color: #fff;
      margin-bottom: 1rem;
      letter-spacing: 0.05em;
    }

    .footer-col ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .footer-col a {
      font-size: 0.82rem;
      color: var(--muted);
      transition: color 0.18s;
    }

    .footer-col a:hover { color: #EE359E; }

    .footer-bottom {
      border-top: 1px solid var(--rule);
      max-width: 1100px;
      margin: 0 auto;
      padding: 1.2rem 2rem;
    }

    .footer-bottom span {
      font-size: 0.75rem;
      color: var(--muted);
    }

    @media (max-width: 640px) {
      .header-nav { display: none; }
      .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
    }

    @media (max-width: 420px) {
      .footer-inner { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
  </script>
</body>
</html>
