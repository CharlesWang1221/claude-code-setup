---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Base title="網誌" description="老查與阿分的文字基地，記錄每一集背後的思考碎片。">
  <section class="blog-hero">
    <div class="container">
      <p class="section-eyebrow reveal">網誌</p>
      <h1 class="blog-title reveal reveal-d1">文字的<br />不標準答案</h1>
      <p class="blog-sub reveal reveal-d2">每篇文章，都是對「標準答案」的一次溫柔抵抗。</p>
    </div>
  </section>

  <section class="blog-list container">
    {posts.map((post, i) => (
      <a href={`/blog/${post.slug}`} class="blog-card reveal">
        {post.data.image && (
          <div class="blog-card-img" style={`background-image:url('${post.data.image}')`}></div>
        )}
        <div class="blog-card-body">
          <time class="blog-date">{post.data.date}</time>
          <h2 class="blog-card-title">{post.data.title}</h2>
          {post.data.description && (
            <p class="blog-card-desc">{post.data.description}</p>
          )}
          <span class="blog-read-more">閱讀全文 →</span>
        </div>
      </a>
    ))}
  </section>
</Base>

<style>
  .blog-hero {
    padding: 6rem 0 4rem;
    background: linear-gradient(180deg, #1A0A45 0%, #15083A 100%);
    border-bottom: 1px solid var(--rule);
  }

  .blog-title {
    font-family: var(--heading);
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    background: linear-gradient(135deg, #EE359E 0%, #815BDB 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0.6rem 0 1rem;
    text-wrap: balance;
  }

  .blog-sub {
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 500px;
  }

  .blog-list {
    padding: 4rem 0 6rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .blog-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    padding: 1.75rem 1.75rem 1.75rem 2rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-left: 3px solid var(--accent2);
    border-radius: 3px;
    transition: border-color 0.2s, background 0.2s;
    cursor: pointer;
  }

  .blog-card:hover {
    background: rgba(238, 53, 158, 0.07);
    border-color: var(--accent);
    border-left-color: var(--accent);
  }

  .blog-card-img {
    width: 100%;
    aspect-ratio: 16/7;
    background-size: cover;
    background-position: center;
    border-radius: 3px;
    margin-bottom: 1.2rem;
  }

  .blog-date {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    display: block;
    margin-bottom: 0.5rem;
  }

  .blog-card-title {
    font-family: var(--serif);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 700;
    line-height: 1.35;
    color: var(--body);
    margin-bottom: 0.6rem;
    transition: color 0.18s;
  }

  .blog-card:hover .blog-card-title { color: var(--accent); }

  .blog-card-img { border-radius: 2px; }

  .blog-card-desc {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 0.8rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-read-more {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    background: linear-gradient(135deg, #EE359E, #815BDB);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @media (max-width: 640px) {
    .blog-list { gap: 0.75rem; }
    .blog-card { padding: 1.25rem; }
  }
</style>
