---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug);
if (!post) return Astro.redirect('/blog');

const { Content } = await post.render();

const siteUrl = 'https://beyond-ans.com';
const cleanDesc = (post.data.description || '').replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: cleanDesc.slice(0, 500),
  url: `${siteUrl}/blog/${post.slug}`,
  datePublished: post.data.date,
  image: post.data.image,
  mainEntityOfPage: `${siteUrl}/blog/${post.slug}`,
  author: [
    { '@type': 'Person', name: '老查' },
    { '@type': 'Person', name: '阿分' },
  ],
};
---

<Base title={post.data.title} description={post.data.description} ogImage={post.data.image} type="article" keywords={post.data.tags}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <article class="blog-post">
    <div class="post-hero">
      <div class="container">
        <a href="/blog" class="back-link">← 回網誌</a>
        <time class="post-date">{post.data.date}</time>
        <h1 class="post-title">{post.data.title}</h1>
        {post.data.description && (
          <p class="post-desc">{post.data.description}</p>
        )}
      </div>
    </div>
    {post.data.image && (
      <div class="post-cover container">
        <img src={post.data.image} alt={post.data.title} loading="lazy" />
      </div>
    )}
    <div class="post-body container">
      <Content />
    </div>
  </article>
</Base>

<style>
  .post-hero {
    padding: 5rem 0 3rem;
    background: linear-gradient(180deg, #1A0A45 0%, #15083A 100%);
    border-bottom: 1px solid var(--rule);
  }

  .back-link {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--muted);
    transition: color 0.18s;
    display: block;
    margin-bottom: 2rem;
  }

  .back-link:hover { color: var(--accent); }

  .post-date {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    display: block;
    margin-bottom: 0.8rem;
  }

  .post-title {
    font-family: var(--heading);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #EE359E 0%, #815BDB 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .post-desc {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 560px;
  }

  .post-cover {
    padding: 2.5rem 0 0;
  }

  .post-cover img {
    width: 100%;
    border-radius: 4px;
    display: block;
  }

  .post-body {
    padding: 3rem 0 6rem;
    max-width: 680px;
  }

  .post-body :global(p) {
    font-size: 1rem;
    line-height: 1.85;
    color: var(--body);
    margin-bottom: 1.6rem;
  }

  .post-body :global(h2) {
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--body);
    margin: 2.5rem 0 1rem;
  }

  .post-body :global(h3) {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--body);
    margin: 2rem 0 0.8rem;
  }

  .post-body :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 1.2rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--muted);
  }

  .post-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
