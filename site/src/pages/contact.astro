---
import Base from '../layouts/Base.astro';
---

<Base title="聯絡我們 | 不標準答案" description="有任何想法、合作提案或節目建議，都歡迎寫信給我們。">
  <section class="contact-hero">
    <div class="container">
      <span class="section-eyebrow reveal">Contact</span>
      <h1 class="contact-title reveal reveal-d1">聯絡我們</h1>
      <p class="contact-sub reveal reveal-d2">有想法、合作提案、或只是想說聲嗨，都歡迎。</p>
    </div>
  </section>

  <section class="contact-body container">
    <div class="contact-card reveal">
      <div class="contact-icon">✉</div>
      <h2 class="contact-label">Email</h2>
      <a href="mailto:another20251021@gmail.com" class="contact-email">
        another20251021@gmail.com
      </a>
      <p class="contact-note">我們通常會在 2–3 個工作天內回覆。</p>
    </div>

    <div class="contact-card reveal reveal-d1">
      <div class="contact-icon">💬</div>
      <h2 class="contact-label">社群</h2>
      <div class="social-links">
        <a href="https://www.instagram.com/another20251021/" target="_blank" rel="noopener">Instagram</a>
        <a href="https://www.facebook.com" target="_blank" rel="noopener">Facebook</a>
        <a href="https://www.youtube.com" target="_blank" rel="noopener">YouTube</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-hero {
    padding: 6rem 0 4rem;
    background: linear-gradient(180deg, #1A0A45 0%, #15083A 100%);
    border-bottom: 1px solid var(--rule);
  }

  .contact-title {
    font-family: var(--heading);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .contact-sub {
    font-size: 1rem;
    color: var(--muted);
    max-width: 480px;
  }

  .contact-body {
    padding: 5rem 0 6rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .contact-card {
    background: var(--surface);
    border-radius: 12px;
    padding: 2.5rem 2rem;
    border: 1px solid var(--rule);
    transition: border-color 0.2s, transform 0.2s;
  }

  .contact-card:hover {
    border-color: rgba(238,53,158,0.4);
    transform: translateY(-3px);
  }

  .contact-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .contact-label {
    font-family: var(--heading);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.8rem;
  }

  .contact-email {
    display: inline-block;
    font-family: var(--heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.8rem;
    transition: color 0.18s;
    word-break: break-all;
  }

  .contact-email:hover { color: var(--accent); }

  .contact-note {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .social-links a {
    font-family: var(--heading);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    transition: color 0.18s;
  }

  .social-links a:hover { color: var(--accent); }
</style>
