---
import Base from '../layouts/Base.astro';

const videos = [
  // 之後在這裡補上影片資料，格式如下：
  // {
  //   id: 'YouTube影片ID',
  //   title: '影片標題',
  //   date: '2026-01-01',
  //   description: '影片描述',
  // },
];
---

<Base title="影音 | 不標準答案" description="《不標準答案》YouTube 影片頻道，用鏡頭記錄每一集的思考現場。">
  <section class="videos-hero">
    <div class="container">
      <p class="section-eyebrow reveal">影音</p>
      <h1 class="videos-title reveal reveal-d1">用鏡頭說<br />不標準答案</h1>
      <p class="videos-sub reveal reveal-d2">Podcast 之外，我們也在鏡頭前說話。</p>
      <a
        href="https://www.youtube.com/@beyondanswersTW"
        target="_blank"
        rel="noopener noreferrer"
        class="yt-btn reveal reveal-d3"
      >
        訂閱 YouTube 頻道 →
      </a>
    </div>
  </section>

  <section class="videos-grid container">
    {videos.length === 0 ? (
      <div class="empty-state">
        <p class="empty-icon">🎬</p>
        <p class="empty-text">影片內容即將上線</p>
        <p class="empty-sub">先去 YouTube 訂閱，不錯過任何更新。</p>
      </div>
    ) : (
      videos.map((v) => (
        <a
          href={`https://www.youtube.com/watch?v=${v.id}`}
          target="_blank"
          rel="noopener noreferrer"
          class="video-card reveal"
        >
          <div class="video-thumb">
            <img
              src={`https://img.youtube.com/vi/${v.id}/mqdefault.jpg`}
              alt={v.title}
              loading="lazy"
            />
            <div class="play-btn">▶</div>
          </div>
          <div class="video-info">
            <time class="video-date">{v.date}</time>
            <h2 class="video-title">{v.title}</h2>
            {v.description && <p class="video-desc">{v.description}</p>}
          </div>
        </a>
      ))
    )}
  </section>
</Base>

<style>
  .videos-hero {
    padding: 6rem 0 4rem;
    background: linear-gradient(180deg, #1A0A45 0%, #15083A 100%);
    border-bottom: 1px solid var(--rule);
  }

  .videos-title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    background: linear-gradient(135deg, #EE359E 0%, #815BDB 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0.6rem 0 1rem;
    text-wrap: balance;
  }

  .videos-sub {
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 500px;
    margin-bottom: 1.8rem;
  }

  .yt-btn {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    background: linear-gradient(135deg, #EE359E, #815BDB);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    border: 1px solid rgba(238,53,158,0.35);
    padding: 0.6rem 1.2rem;
    border-radius: 2px;
    transition: border-color 0.2s, background 0.2s;
  }

  .yt-btn:hover {
    border-color: rgba(238,53,158,0.7);
    background: linear-gradient(135deg, rgba(238,53,158,0.08), rgba(129,91,219,0.08));
    -webkit-text-fill-color: unset;
    color: #815BDB;
  }

  .videos-grid {
    padding: 4rem 0 6rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 5rem 0;
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .empty-text {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--body);
    margin-bottom: 0.5rem;
  }

  .empty-sub {
    font-size: 0.88rem;
    color: var(--muted);
  }

  .video-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    cursor: pointer;
  }

  .video-thumb {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    border-radius: 3px;
    background: #0F0235;
  }

  .video-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .video-card:hover .video-thumb img { transform: scale(1.04); }

  .play-btn {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: white;
    background: rgba(0,0,0,0.3);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .video-card:hover .play-btn { opacity: 1; }

  .video-date {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    display: block;
  }

  .video-title {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--body);
    transition: color 0.18s;
  }

  .video-card:hover .video-title { color: var(--accent); }

  .video-desc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
