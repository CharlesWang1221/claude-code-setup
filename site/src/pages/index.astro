---
import Base from '../layouts/Base.astro';
import { getFeed } from '../lib/feed';
import { getCollection } from 'astro:content';

const { episodes, meta } = await getFeed();
const latest = episodes[0];
const blogPosts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);
const cards = episodes.slice(0, 3);

const siteUrl = 'https://podcast-site-9hr.pages.dev';
const podcastSchema = {
  '@context': 'https://schema.org',
  '@type': 'PodcastSeries',
  name: meta.title,
  description: meta.description.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim().slice(0, 300),
  url: siteUrl,
  image: meta.image,
  author: [
    { '@type': 'Person', name: '老查' },
    { '@type': 'Person', name: '阿分' },
  ],
  webFeed: 'https://feed.firstory.me/rss/user/cmi76pcj000h7010chgezh8bs',
};
---

<Base title="不標準答案" description={meta.description}>
  <script type="application/ld+json" set:html={JSON.stringify(podcastSchema)} />

  <!-- ══ INTRO OVERLAY ══ -->
  <div id="intro-overlay">
    <canvas id="intro-canvas"></canvas>
    <div id="intro-pct">0%</div>
  </div>

  <!-- ══ HERO ══ -->
  <section class="hero">
    <div class="hero-orb"></div>
    <div class="hero-body">
      <p class="hero-eyebrow reveal">Podcast · 每週更新</p>
      <h1 class="hero-title reveal reveal-d1">
        找到屬於你的<br />不標準答案
      </h1>
      <p class="hero-sub reveal reveal-d2">老查與阿分的 Podcast。在日常觀察裡，找破框的角度。</p>
      <div class="hero-actions reveal reveal-d3">
        <a href={`/episodes/${latest.slug}`} class="btn-pill-primary">開始收聽</a>
        <a href="/episodes" class="btn-pill-ghost">瀏覽所有集數</a>
      </div>
    </div>
  </section>

  <!-- ══ PLATFORM BADGES ══ -->
  <section class="platforms">
    <div class="platforms-inner container">
      <span class="platforms-label">收聽平台</span>
      <div class="platforms-list">
        <a href="https://open.firstory.me/user/cmi76pcj000h7010chgezh8bs" target="_blank" rel="noopener" class="platform-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="white"/></svg>
          Firstory
        </a>
        <a href="#" target="_blank" rel="noopener" class="platform-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
          Apple Podcasts
        </a>
        <a href="#" target="_blank" rel="noopener" class="platform-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
          Spotify
        </a>
        <a href="https://feed.firstory.me/rss/user/cmi76pcj000h7010chgezh8bs" target="_blank" rel="noopener" class="platform-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
          RSS
        </a>
      </div>
    </div>
  </section>

  <!-- ══ ABOUT ══ -->
  <section class="about-section" id="about">
    <div class="container about-inner">
      <div class="about-img-wrap reveal">
        <div class="about-img" style="background-image:url('/hero.png')"></div>
      </div>
      <div class="about-text reveal reveal-d1">
        <p class="section-eyebrow">關於節目</p>
        <h2 class="about-heading">不標準答案</h2>
        <p class="about-desc">《不標準答案》是老查與阿分的 Podcast。我們不給標準答案，因為這個世界的問題，從來就沒有標準答案。</p>
        <p class="about-desc">每週一更新，每集 30–60 分鐘。透過一家四口的日常感知，對世俗的理所當然提出溫柔的提問。</p>
        <a href="/episodes" class="btn-pill-primary" style="margin-top:1rem">收聽節目</a>
      </div>
    </div>
  </section>

  <!-- ══ LATEST EPISODES ══ -->
  <section class="episodes-section">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="section-eyebrow reveal">最新集數</p>
          <h2 class="section-title reveal reveal-d1">最新 Podcast</h2>
        </div>
        <a href="/episodes" class="all-link reveal">查看全部 →</a>
      </div>
      <div class="ep-cards-grid">
        {cards.map((ep, i) => (
          <a href={`/episodes/${ep.slug}`} class={`ep-card reveal reveal-d${i + 1}`}>
            <div class="ep-card-thumb">
              <img src={ep.image || meta.image} alt={ep.title} loading="lazy" />
              <span class="ep-badge">{ep.episodeLabel}</span>
            </div>
            <div class="ep-card-body">
              <h3 class="ep-card-title">{ep.title}</h3>
              <div class="ep-card-meta">
                <time>{ep.pubDateFormatted}</time>
                <span>·</span>
                <span>{ep.duration}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ BLOG ══ -->
  {blogPosts.length > 0 && (
    <section class="blog-section">
      <div class="container">
        <div class="section-header">
          <div>
            <p class="section-eyebrow reveal">網誌</p>
            <h2 class="section-title reveal reveal-d1">最新文章</h2>
          </div>
          <a href="/blog" class="all-link reveal">查看全部 →</a>
        </div>
        <div class="blog-grid">
          {blogPosts.map((post, i) => (
            <a href={`/blog/${post.slug}`} class={`blog-card reveal reveal-d${(i % 2) + 1}`}>
              {post.data.image && (
                <div class="blog-card-thumb">
                  <img src={post.data.image} alt={post.data.title} loading="lazy" />
                </div>
              )}
              <div class="blog-card-body">
                <time class="blog-card-date">{post.data.date}</time>
                <h3 class="blog-card-title">{post.data.title}</h3>
                {post.data.description && <p class="blog-card-desc">{post.data.description}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══ EPISODE LIST ══ -->
  <section class="list-section container">
    <div class="list-header-row">
      <span class="section-label">所有集數</span>
      <a href="/episodes" class="all-link">查看全部 →</a>
    </div>
    <ul class="episode-list">
      {episodes.slice(3, 7).map((ep) => (
        <li class="episode-item reveal" onclick={`location.href='/episodes/${ep.slug}'`}>
          <span class="ep-num">{ep.episodeLabel}</span>
          <div>
            <div class="ep-title">{ep.title}</div>
            <div class="ep-date">{ep.pubDateFormatted}</div>
          </div>
          <span class="ep-dur">{ep.duration}</span>
        </li>
      ))}
    </ul>
  </section>

</Base>

<script>
(function () {
  const overlay = document.getElementById('intro-overlay');
  const canvas  = document.getElementById('intro-canvas');
  const pctEl   = document.getElementById('intro-pct');
  if (!overlay || !canvas || !pctEl) return;

  const ctx = canvas.getContext('2d');
  const DURATION = 4800;

  function resize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  function cx() { return canvas.width  / 2; }
  function cy() { return canvas.height / 2; }

  const PALETTE = [
    { color: '#815BDB', r: 26 },
    { color: '#EE359E', r: 20 },
    { color: '#5566EE', r: 22 },
    { color: '#FF88CC', r: 13 },
    { color: '#EE359E', r: 15 },
    { color: '#9966FF', r: 11 },
    { color: '#AADD22', r:  8 },
    { color: '#6644DD', r: 17 },
    { color: '#FF66AA', r:  9 },
    { color: '#AADD22', r:  6 },
    { color: '#CC77FF', r: 13 },
    { color: '#4488FF', r: 10 },
  ];

  function edgePos() {
    const w = canvas.width, h = canvas.height;
    const edge = (Math.random() * 4) | 0;
    return edge === 0 ? { x: Math.random() * w, y: -60 }
         : edge === 1 ? { x: w + 60, y: Math.random() * h }
         : edge === 2 ? { x: Math.random() * w, y: h + 60 }
                      : { x: -60, y: Math.random() * h };
  }

  let nodes = [];
  function initNodes() {
    const spread = Math.min(canvas.width, canvas.height) * 0.34;
    nodes = PALETTE.map((cfg, i) => {
      const angle = (i / PALETTE.length) * Math.PI * 2 + (Math.random() - 0.5) * 0.7;
      const dist  = spread * (0.45 + Math.random() * 0.55);
      const start = edgePos();
      return {
        ...cfg,
        tx: cx() + Math.cos(angle) * dist,
        ty: cy() + Math.sin(angle) * dist,
        sx: start.x, sy: start.y,
        x: start.x,  y: start.y,
        delay: i * 130 + Math.random() * 180,
      };
    });
  }

  const easeOut = t => 1 - Math.pow(1 - t, 3);
  const easeIn  = t => t * t * t;

  const FLY_END  = 0.70;
  const HOLD_END = 0.84;

  let startTime = null;

  function draw(ts) {
    if (!startTime) { startTime = ts; initNodes(); }
    const elapsed  = ts - startTime;
    const progress = Math.min(elapsed / DURATION, 1);
    const w = canvas.width, h = canvas.height;

    ctx.clearRect(0, 0, w, h);

    // counter
    pctEl.textContent = Math.min(Math.floor(progress * 100), 100) + '%';

    nodes.forEach(node => {
      const ne = elapsed - node.delay;
      let nx, ny;

      if (progress < FLY_END) {
        const flyDur = DURATION * FLY_END - node.delay;
        const t = Math.max(0, Math.min(ne / flyDur, 1));
        nx = node.sx + (node.tx - node.sx) * easeOut(t);
        ny = node.sy + (node.ty - node.sy) * easeOut(t);
      } else if (progress < HOLD_END) {
        nx = node.tx; ny = node.ty;
      } else {
        const t = (progress - HOLD_END) / (1 - HOLD_END);
        nx = node.tx + (cx() - node.tx) * easeIn(t);
        ny = node.ty + (cy() - node.ty) * easeIn(t);
      }

      node.x = nx; node.y = ny;
      if (ne <= 0) return;

      const collapseT = progress < HOLD_END ? 0 : (progress - HOLD_END) / (1 - HOLD_END);
      const alpha = 1 - easeIn(collapseT);
      const lineA = 0.28 * alpha;

      // line
      ctx.beginPath();
      ctx.moveTo(cx(), cy());
      ctx.lineTo(nx, ny);
      ctx.strokeStyle = `rgba(200,180,255,${lineA})`;
      ctx.lineWidth = 0.9;
      ctx.stroke();

      // glow + node
      const curR = node.r * (1 - collapseT * 0.6);
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.shadowColor = node.color;
      ctx.shadowBlur  = curR * 1.2;
      ctx.beginPath();
      ctx.arc(nx, ny, curR, 0, Math.PI * 2);
      ctx.fillStyle = node.color;
      ctx.fill();
      ctx.restore();
    });

    // hub
    const hubR = 4 + easeIn(progress < HOLD_END ? 0 : (progress - HOLD_END) / (1 - HOLD_END)) * 18;
    ctx.save();
    ctx.shadowColor = '#C0A0FF';
    ctx.shadowBlur  = 20;
    ctx.beginPath();
    ctx.arc(cx(), cy(), hubR, 0, Math.PI * 2);
    ctx.fillStyle = '#D0B0FF';
    ctx.fill();
    ctx.restore();

    if (progress < 1) {
      requestAnimationFrame(draw);
    } else {
      overlay.classList.add('done');
      document.body.style.overflow = '';
      setTimeout(() => overlay.remove(), 700);
    }
  }

  document.body.style.overflow = 'hidden';
  requestAnimationFrame(draw);
})();
</script>

<style>
  /* ══ INTRO OVERLAY ══ */
  #intro-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--bg);
    pointer-events: none;
    transition: opacity 0.65s ease;
  }
  #intro-overlay.done { opacity: 0; }

  #intro-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #intro-pct {
    position: absolute;
    bottom: 2.2rem;
    right: 2.5rem;
    font-family: var(--heading);
    font-size: 1.4rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    color: rgba(200, 180, 255, 0.65);
  }

  /* ══ HERO ══ */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
  }

  .hero-orb {
    position: absolute;
    bottom: -55%;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(520px, 85vw, 1100px);
    height: clamp(520px, 85vw, 1100px);
    border-radius: 50%;
    background: radial-gradient(
      circle at 38% 30%,
      rgba(255, 170, 215, 1)   0%,
      rgba(238, 53, 158, 0.95) 18%,
      rgba(162, 80, 220, 0.85) 42%,
      rgba(80,  30, 160, 0.55) 68%,
      transparent              100%
    );
    filter: blur(45px);
    pointer-events: none;
    animation: orb-breathe 7s ease-in-out infinite;
  }

  @keyframes orb-breathe {
    0%, 100% { transform: translateX(-50%) scale(1);    opacity: 0.85; }
    50%       { transform: translateX(-50%) scale(1.06); opacity: 1;    }
  }

  .hero-body {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 6rem 2rem 4rem;
    max-width: 760px;
  }

  .hero-eyebrow {
    font-family: var(--heading);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    margin: 0;
    text-shadow: 0 1px 12px rgba(0,0,0,0.6);
  }

  .hero-title {
    font-family: var(--heading);
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #fff;
    text-wrap: balance;
    text-shadow: 0 2px 30px rgba(0,0,0,0.5);
  }

  .hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.82);
    line-height: 1.7;
    max-width: 480px;
    margin: 0;
    text-shadow: 0 1px 12px rgba(0,0,0,0.55);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .btn-pill-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 2rem;
    background: linear-gradient(135deg, #EE359E 0%, #815BDB 100%);
    color: #fff;
    font-family: var(--heading);
    font-size: 0.88rem;
    font-weight: 700;
    border-radius: 50px;
    transition: opacity 0.2s, transform 0.2s;
    box-shadow: 0 4px 20px rgba(238,53,158,0.35);
  }

  .btn-pill-primary:hover { opacity: 0.88; transform: translateY(-2px); }

  .btn-pill-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 2rem;
    border: 1px solid rgba(238,53,158,0.4);
    color: var(--body);
    font-family: var(--heading);
    font-size: 0.88rem;
    font-weight: 700;
    border-radius: 50px;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-pill-ghost:hover { border-color: var(--accent); color: var(--accent); }

  /* ══ PLATFORMS ══ */
  .platforms {
    background: var(--surface);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 1.2rem 0;
  }

  .platforms-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .platforms-label {
    font-family: var(--heading);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }

  .platforms-list {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .platform-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.42rem 1rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--rule);
    border-radius: 50px;
    font-size: 0.78rem;
    font-family: var(--heading);
    font-weight: 700;
    color: var(--muted);
    transition: border-color 0.2s, color 0.2s;
  }

  .platform-badge:hover { border-color: var(--accent); color: #fff; }

  /* ══ ABOUT ══ */
  .about-section {
    padding: 6rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .about-img-wrap {
    position: relative;
  }

  .about-img {
    width: 100%;
    aspect-ratio: 4/5;
    background-size: cover;
    background-position: center;
    border-radius: 12px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.45);
  }

  .about-heading {
    font-family: var(--heading);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 1.2rem;
  }

  .about-desc {
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 0.8rem;
  }

  /* ══ LATEST EPISODES ══ */
  .episodes-section {
    padding: 5rem 0;
    background: var(--surface);
    border-bottom: 1px solid var(--rule);
  }

  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-family: var(--heading);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 900;
    letter-spacing: -0.025em;
    color: #fff;
  }

  .all-link {
    font-family: var(--heading);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--accent);
    transition: opacity 0.2s;
    padding-bottom: 0.15rem;
  }

  .all-link:hover { opacity: 0.75; }

  .ep-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .ep-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--rule);
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
  }

  .ep-card:hover {
    border-color: rgba(238,53,158,0.4);
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.35);
  }

  .ep-card-thumb {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .ep-card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .ep-card:hover .ep-card-thumb img { transform: scale(1.05); }

  .ep-badge {
    position: absolute;
    top: 0.65rem;
    left: 0.65rem;
    background: rgba(238,53,158,0.9);
    color: #fff;
    font-family: var(--heading);
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.55rem;
    border-radius: 50px;
    text-transform: uppercase;
  }

  .ep-card-body {
    padding: 1rem 1.1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    flex: 1;
  }

  .ep-card-title {
    font-family: var(--heading);
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--body);
    transition: color 0.18s;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ep-card:hover .ep-card-title { color: #fff; }

