---
import Base from '../layouts/Base.astro';
import { getFeed } from '../lib/feed';

const { episodes, meta } = await getFeed();
const latest = episodes[0];
const cards = episodes.slice(0, 3);
const feature = episodes[3];

const siteUrl = 'https://podcast-site-9hr.pages.dev';
const podcastSchema = {
  '@context': 'https://schema.org',
  '@type': 'PodcastSeries',
  name: meta.title,
  description: meta.description.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim().slice(0, 300),
  url: siteUrl,
  image: meta.image,
  author: [
    { '@type': 'Person', name: '老查' },
    { '@type': 'Person', name: '阿分' },
  ],
  webFeed: 'https://feed.firstory.me/rss/user/cmi76pcj000h7010chgezh8bs',
};
---

<Base title="不標準答案" description={meta.description}>
  <script type="application/ld+json" set:html={JSON.stringify(podcastSchema)} />

  <!-- ══ HERO ══ -->
  <section class="hero">
    <div class="hero-bg" style="background-image:url('/hero.png')"></div>
    <div class="hero-overlay"></div>

    <div class="hero-body">
      <p class="hero-eyebrow">
        <span class="brand-icon">◎</span> 不標準答案
      </p>
      <h1 class="hero-title">
        找到屬於你的<br />不標準答案
      </h1>
      <a href={`/episodes/${latest.slug}`} class="btn-cta">開始收聽</a>
    </div>

    <!-- player bar -->
    <div class="hero-player">
      <div class="player-inner">
        <button class="play-btn" aria-label="播放" onclick={`document.getElementById('hero-audio').paused?document.getElementById('hero-audio').play():document.getElementById('hero-audio').pause()`}>▶</button>
        <span class="player-label">{latest.episodeLabel} — {latest.title}</span>
        <div class="progress-track" id="progress-track">
          <div class="progress-fill" id="progress-fill"></div>
        </div>
        <span class="player-time" id="player-time">00:00 / {latest.duration}</span>
        <span class="player-vol">◈</span>
      </div>
      <audio id="hero-audio" src={latest.audioUrl} preload="none"></audio>
    </div>
  </section>

  <!-- ══ CARDS ══ -->
  <section class="cards-section">
    <div class="container">
      <p class="section-eyebrow reveal">最新集數</p>
      <h2 class="section-heading reveal reveal-d1">More Latest Podcasts</h2>
      <div class="cards-grid">
        {cards.map((ep, i) => (
          <a href={`/episodes/${ep.slug}`} class={`card reveal reveal-d${i + 1}`}>
            <div class="card-bg" style={`background-image:url('${ep.image || meta.image}')`}></div>
            <div class="card-dark"></div>
            <div class="card-foot">
              <span class="card-num">Volume Number {String(i + 1).padStart(2, '0')}</span>
              <span class="card-title">{ep.title}</span>
            </div>
          </a>
        ))}
      </div>

      <!-- HOST CARDS -->
      <div class="hosts-grid">
        <div class="host-card reveal reveal-d1">
          <div class="host-bg" style="background-image:url('/hero.png');background-position:28% center;"></div>
          <div class="host-dark"></div>
          <div class="host-content">
            <span class="host-role">探險家</span>
            <h3 class="host-name">老查</h3>
            <p class="host-desc">擅長專業執行與思辨實踐，用獨特的堅持，碰撞出真實的火花。</p>
          </div>
        </div>
        <div class="host-card reveal reveal-d2">
          <div class="host-bg" style="background-image:url('/hero.png');background-position:72% center;"></div>
          <div class="host-dark"></div>
          <div class="host-content">
            <span class="host-role">哲思家</span>
            <h3 class="host-name">阿分</h3>
            <p class="host-desc">擅長發呆與感知生活的純粹，為你熬煮一碗溫暖的哲學湯。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ FEATURE ══ -->
  {feature && (
    <section class="feature-section">
      <div class="container feature-inner">
        <div class="feature-text reveal">
          <p class="section-eyebrow">Services &amp; Features</p>
          <h2 class="feature-heading">每週一集<br />破框觀點</h2>
          <p class="feature-sub">{feature.title}</p>
          <p class="feature-desc">老查與阿分透過一家四口的日常感知，對世俗的理所當然提出溫柔的提問。每週更新，每集 30–60 分鐘。</p>
          <a href={`/episodes/${feature.slug}`} class="btn-cta">收聽這集</a>
        </div>
        <div class="feature-img-wrap reveal reveal-d2">
          <div class="feature-img" style={`background-image:url('${feature.image || meta.image}')`}></div>
        </div>
      </div>
    </section>
  )}

  <!-- ══ QUOTE ══ -->
  <section class="quote-section">
    <div class="container">
      <blockquote class="quote-text reveal">
        最迷人的真實人生，往往綻放在既定框架之外。
      </blockquote>
      <cite class="quote-cite reveal reveal-d2">— 老查 &amp; 阿分</cite>
    </div>
  </section>

  <!-- ══ ALL EPISODES ══ -->
  <section class="list-section container">
    <div class="list-header">
      <span class="section-label">所有集數</span>
      <a href="/episodes" class="all-link">查看全部 →</a>
    </div>
    <ul class="episode-list">
      {episodes.slice(3, 7).map((ep) => (
        <li class="episode-item reveal" onclick={`location.href='/episodes/${ep.slug}'`}>
          <span class="ep-num">{ep.episodeLabel}</span>
          <div>
            <div class="ep-title">{ep.title}</div>
            <div class="ep-date">{ep.pubDateFormatted}</div>
          </div>
          <span class="ep-dur">{ep.duration}</span>
        </li>
      ))}
    </ul>
  </section>

  <!-- ══ ABOUT ══ -->
  <section class="about-section container" id="about">
    <div class="section-label">About</div>
    <div class="about-body">
      <p>《不標準答案》是老查與阿分的 Podcast。我們不給標準答案，因為這個世界的問題，從來就沒有標準答案。</p>
      <p>每週一更新。每集 30–60 分鐘。在日常觀察裡找破框的角度。</p>
      <div class="sub-row">
        <a href="https://open.firstory.me/user/cmi76pcj000h7010chgezh8bs" target="_blank" rel="noopener" class="btn-outline">Firstory</a>
        <a href="#" class="btn-outline">Apple Podcasts</a>
        <a href="#" class="btn-outline">Spotify</a>
        <a href="#" class="btn-outline">YouTube</a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ══ HERO ══ */
  .hero {
    position: relative;
    height: 100svh;
    min-height: 560px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center top;
    transform: scale(1.04);
    transition: transform 8s ease;
  }

  .hero:hover .hero-bg { transform: scale(1); }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg { transform: none !important; }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 45%, rgba(10,8,6,0.1) 0%, rgba(10,8,6,0.65) 100%),
      linear-gradient(to bottom, rgba(10,8,6,0.5) 0%, rgba(10,8,6,0.08) 35%, rgba(10,8,6,0.6) 80%, rgba(10,8,6,0.92) 100%);
  }

  .hero-body {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.8rem;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    color: rgba(248,245,240,0.75);
    text-transform: uppercase;
  }

  .brand-icon {
    color: var(--accent);
    font-size: 0.9rem;
  }

  .hero-title {
    font-family: var(--serif);
    font-size: clamp(2.6rem, 7vw, 5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: #F8F5F0;
    text-wrap: balance;
    text-shadow: 0 2px 32px rgba(0,0,0,0.6), 0 0 60px rgba(0,0,0,0.35);
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 2rem;
    background: linear-gradient(135deg, #C0A062 0%, #E8C878 100%);
    color: #1A1408;
    font-family: var(--serif);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    cursor: pointer;
    border-radius: 2px;
    transition: opacity 0.2s, transform 0.2s;
  }

  .btn-cta:hover {
    opacity: 0.85;
    transform: translateY(-2px);
  }

  .btn-cta:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

  /* player bar */
  .hero-player {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 3;
    background: rgba(10,8,6,0.82);
    backdrop-filter: blur(12px);
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  .player-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0.9rem 2rem;
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .play-btn {
    background: var(--accent);
    border: none;
    color: #fff;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    font-size: 0.7rem;
    cursor: pointer;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: 2px;
    transition: background 0.18s;
  }

  .play-btn:hover { background: #a83835; }

  .player-label {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: rgba(248,245,240,0.55);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 240px;
  }

  .progress-track {
    flex: 1;
    height: 3px;
    background: rgba(192,160,98,0.15);
    border-radius: 2px;
    cursor: pointer;
    position: relative;
  }

  .progress-fill {
    width: 0%;
    height: 100%;
    background: linear-gradient(90deg, #C0A062, #E8C878);
    border-radius: 2px;
    transition: width 0.5s linear;
  }

  .player-time {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: rgba(248,245,240,0.45);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .player-vol {
    font-size: 0.8rem;
    color: rgba(248,245,240,0.45);
    cursor: pointer;
  }

  /* ══ CARDS ══ */
  .cards-section {
    padding: 5rem 0;
    background: linear-gradient(180deg, #0E0D0B 0%, #161310 60%, #0E0D0B 100%);
  }

  .section-eyebrow {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }

  .section-heading {
    font-family: var(--serif);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 2.5rem;
    text-wrap: balance;
    background: var(--grad-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }

  .card {
    position: relative;
    display: block;
    aspect-ratio: 3/4;
    overflow: hidden;
    border-radius: 4px;
    cursor: pointer;
    box-shadow: 0 2px 16px rgba(0,0,0,0.35);
    transition: box-shadow 0.3s, transform 0.3s;
  }

  .card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.55);
    transform: translateY(-4px);
  }

  .card-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.5s ease;
  }

  .card:hover .card-bg { transform: scale(1.04); }

  .card-dark {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(13,12,11,0.05) 0%,
      rgba(13,12,11,0.72) 65%,
      rgba(13,12,11,0.96) 100%
    );
  }

  .card-foot {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .card-num {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: rgba(240,237,232,0.6);
  }

  .card-title {
    font-family: var(--serif);
    font-size: 0.95rem;
    line-height: 1.4;
    color: var(--body);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ══ HOST CARDS ══ */
  .hosts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
    margin-top: 1.2rem;
  }

  .host-card {
    position: relative;
    aspect-ratio: 16/7;
    overflow: hidden;
    border-radius: 4px;
    cursor: default;
    box-shadow: 0 2px 12px rgba(28,25,23,0.08);
  }

  .host-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    transition: transform 0.6s ease;
  }

  .host-card:hover .host-bg { transform: scale(1.04); }

  .host-dark {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10,8,6,0.92) 0%,
      rgba(10,8,6,0.58) 45%,
      rgba(10,8,6,0.2) 100%
    );
  }

  .host-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem 1.4rem;
  }

  .host-role {
    display: block;
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    color: var(--accent);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
  }

  .host-name {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: #F8F5F0;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .host-desc {
    font-size: 0.82rem;
    color: rgba(248,245,240,0.65);
    line-height: 1.65;
  }

  /* ══ FEATURE ══ */
  .feature-section {
    padding: 6rem 0;
    background: linear-gradient(180deg, #1A1815 0%, #111009 100%);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .feature-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .feature-heading {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.025em;
    margin: 0.8rem 0 0.6rem;
    text-wrap: balance;
    background: var(--grad-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .feature-sub {
    font-size: 0.75rem;
    font-family: var(--mono);
    letter-spacing: 0.05em;
    color: var(--accent);
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .feature-desc {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .feature-img-wrap {
    position: relative;
  }

  .feature-img {
    width: 100%;
    aspect-ratio: 4/5;
    background-size: cover;
    background-position: center;
    border-radius: 4px;
    box-shadow: 0 4px 32px rgba(0,0,0,0.5);
  }

  /* ══ QUOTE ══ */
  .quote-section {
    padding: 7rem 0;
    text-align: center;
    background: linear-gradient(180deg, #0D0C0B 0%, #171614 50%, #0D0C0B 100%);
  }

  .quote-text {
    font-family: var(--serif);
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    font-style: italic;
    line-height: 1.65;
    color: var(--body);
    max-width: 640px;
    margin: 0 auto 1.2rem;
    text-wrap: balance;
  }

  .quote-cite {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    background: var(--grad-accent);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: normal;
  }

  /* ══ LIST SECTION ══ */
  .list-section {
    padding-bottom: 5rem;
  }

  .list-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-top: 1px solid var(--rule);
    padding-top: 2rem;
    margin-bottom: 0;
  }

  .all-link {
    font-family: var(--mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    color: var(--accent);
    transition: opacity 0.2s;
  }

  .all-link:hover { opacity: 0.7; }

  /* ══ ABOUT ══ */
  .about-section {
    padding-top: 4rem;
    padding-bottom: 5rem;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about-body p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 1.4rem;
  }

  .sub-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ══ RESPONSIVE ══ */
  @media (max-width: 768px) {
    .cards-grid { grid-template-columns: 1fr 1fr; }
    .cards-grid .card:last-child { display: none; }

    .feature-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .feature-img-wrap { order: -1; }
  }

  @media (max-width: 480px) {
    .cards-grid { grid-template-columns: 1fr; }
    .cards-grid .card:last-child { display: block; }
    .cards-grid .card { aspect-ratio: 16/9; }

    .player-label { display: none; }

    .about-section {
      grid-template-columns: 1fr;
      gap: 1.2rem;
      padding-top: 3rem;
    }
  }
</style>

<script>
  const audio = document.getElementById('hero-audio') as HTMLAudioElement | null;
  const fill = document.getElementById('progress-fill') as HTMLElement | null;
  const timeEl = document.getElementById('player-time') as HTMLElement | null;
  const track = document.getElementById('progress-track') as HTMLElement | null;
  const btn = document.querySelector('.play-btn') as HTMLButtonElement | null;

  if (audio && fill && timeEl) {
    function fmt(s: number) {
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
    }

    audio.addEventListener('timeupdate', () => {
      if (!audio.duration) return;
      const pct = (audio.currentTime / audio.duration) * 100;
      fill.style.width = pct + '%';
      timeEl.textContent = `${fmt(audio.currentTime)} / ${fmt(audio.duration)}`;
    });

    audio.addEventListener('play', () => { if (btn) btn.textContent = '⏸'; });
    audio.addEventListener('pause', () => { if (btn) btn.textContent = '▶'; });

    track?.addEventListener('click', (e) => {
      const rect = track.getBoundingClientRect();
      const ratio = (e.clientX - rect.left) / rect.width;
      if (audio.duration) audio.currentTime = ratio * audio.duration;
    });
  }
</script>
