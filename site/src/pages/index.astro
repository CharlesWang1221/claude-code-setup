---
import Base from '../layouts/Base.astro';
import { getFeed } from '../lib/feed';
import { getCollection } from 'astro:content';

const { episodes, meta } = await getFeed();
const latest = episodes[0];
const blogPosts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 4);
const cards = episodes.slice(0, 3);

const siteUrl = 'https://podcast-site-9hr.pages.dev';
const podcastSchema = {
  '@context': 'https://schema.org',
  '@type': 'PodcastSeries',
  name: meta.title,
  description: meta.description.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim().slice(0, 300),
  url: siteUrl,
  image: meta.image,
  author: [
    { '@type': 'Person', name: '老查' },
    { '@type': 'Person', name: '阿分' },
  ],
  webFeed: 'https://feed.firstory.me/rss/user/cmi76pcj000h7010chgezh8bs',
};
---

<Base title="不標準答案" description={meta.description}>
  <script type="application/ld+json" set:html={JSON.stringify(podcastSchema)} />

  <!-- ══ HERO ══ -->
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="hero-body">
      <p class="hero-eyebrow reveal">Podcast · 每週更新</p>
      <h1 class="hero-title reveal reveal-d1">
        找到屬於你的<br />不標準答案
      </h1>
      <p class="hero-sub reveal reveal-d2">老查與阿分的 Podcast。在日常觀察裡，找破框的角度。</p>
      <div class="hero-actions reveal reveal-d3">
        <a href={`/episodes/${latest.slug}`} class="btn-pill-primary">開始收聽</a>
        <a href="/episodes" class="btn-pill-ghost">瀏覽所有集數</a>
      </div>
    </div>
  </section>

  <!-- ══ PLATFORM BADGES ══ -->
  <section class="platforms">
    <div class="platforms-inner container">
      <span class="platforms-label">收聽平台</span>
      <div class="platforms-list">
        <a href="https://open.firstory.me/user/cmi76pcj000h7010chgezh8bs" target="_blank" rel="noopener" class="platform-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="white"/></svg>
          Firstory
        </a>
        <a href="#" target="_blank" rel="noopener" class="platform-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
          Apple Podcasts
        </a>
        <a href="#" target="_blank" rel="noopener" class="platform-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
          Spotify
        </a>
        <a href="https://feed.firstory.me/rss/user/cmi76pcj000h7010chgezh8bs" target="_blank" rel="noopener" class="platform-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
          RSS
        </a>
      </div>
    </div>
  </section>

  <!-- ══ ABOUT ══ -->
  <section class="about-section" id="about">
    <div class="container about-inner">
      <div class="about-img-wrap reveal">
        <div class="about-img" style="background-image:url('/hero.png')"></div>
      </div>
      <div class="about-text reveal reveal-d1">
        <p class="section-eyebrow">關於節目</p>
        <h2 class="about-heading">不標準答案</h2>
        <p class="about-desc">《不標準答案》是老查與阿分的 Podcast。我們不給標準答案，因為這個世界的問題，從來就沒有標準答案。</p>
        <p class="about-desc">每週一更新，每集 30–60 分鐘。透過一家四口的日常感知，對世俗的理所當然提出溫柔的提問。</p>
        <a href="/episodes" class="btn-pill-primary" style="margin-top:1rem">收聽節目</a>
      </div>
    </div>
  </section>

  <!-- ══ LATEST EPISODES ══ -->
  <section class="episodes-section">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="section-eyebrow reveal">最新集數</p>
          <h2 class="section-title reveal reveal-d1">最新 Podcast</h2>
        </div>
        <a href="/episodes" class="all-link reveal">查看全部 →</a>
      </div>
      <div class="ep-cards-grid">
        {cards.map((ep, i) => (
          <a href={`/episodes/${ep.slug}`} class={`ep-card reveal reveal-d${i + 1}`}>
            <div class="ep-card-thumb">
              <img src={ep.image || meta.image} alt={ep.title} loading="lazy" />
              <span class="ep-badge">{ep.episodeLabel}</span>
            </div>
            <div class="ep-card-body">
              <h3 class="ep-card-title">{ep.title}</h3>
              <div class="ep-card-meta">
                <time>{ep.pubDateFormatted}</time>
                <span>·</span>
                <span>{ep.duration}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ BLOG ══ -->
  {blogPosts.length > 0 && (
    <section class="blog-section">
      <div class="container">
        <div class="section-header">
          <div>
            <p class="section-eyebrow reveal">網誌</p>
            <h2 class="section-title reveal reveal-d1">最新文章</h2>
          </div>
          <a href="/blog" class="all-link reveal">查看全部 →</a>
        </div>
        <div class="blog-grid">
          {blogPosts.map((post, i) => (
            <a href={`/blog/${post.slug}`} class={`blog-card reveal reveal-d${(i % 2) + 1}`}>
              {post.data.image && (
                <div class="blog-card-thumb">
                  <img src={post.data.image} alt={post.data.title} loading="lazy" />
                </div>
              )}
              <div class="blog-card-body">
                <time class="blog-card-date">{post.data.date}</time>
                <h3 class="blog-card-title">{post.data.title}</h3>
                {post.data.description && <p class="blog-card-desc">{post.data.description}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══ EPISODE LIST ══ -->
  <section class="list-section container">
    <div class="list-header-row">
      <span class="section-label">所有集數</span>
      <a href="/episodes" class="all-link">查看全部 →</a>
    </div>
    <ul class="episode-list">
      {episodes.slice(3, 7).map((ep) => (
        <li class="episode-item reveal" onclick={`location.href='/episodes/${ep.slug}'`}>
          <span class="ep-num">{ep.episodeLabel}</span>
          <div>
            <div class="ep-title">{ep.title}</div>
            <div class="ep-date">{ep.pubDateFormatted}</div>
          </div>
          <span class="ep-dur">{ep.duration}</span>
        </li>
      ))}
    </ul>
  </section>

</Base>

<style>
  /* ══ HERO ══ */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 55% at 50% 40%, rgba(238,53,158,0.22) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 30% 70%, rgba(129,91,219,0.15) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-body {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 6rem 2rem 4rem;
    max-width: 760px;
  }

  .hero-eyebrow {
    font-family: var(--heading);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
  }

  .hero-title {
    font-family: var(--heading);
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #fff;
    text-wrap: balance;
  }

  .hero-sub {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 480px;
    margin: 0;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .btn-pill-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 2rem;
    background: linear-gradient(135deg, #EE359E 0%, #815BDB 100%);
    color: #fff;
    font-family: var(--heading);
    font-size: 0.88rem;
    font-weight: 700;
    border-radius: 50px;
    transition: opacity 0.2s, transform 0.2s;
    box-shadow: 0 4px 20px rgba(238,53,158,0.35);
  }

  .btn-pill-primary:hover { opacity: 0.88; transform: translateY(-2px); }

  .btn-pill-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 2rem;
    border: 1px solid rgba(238,53,158,0.4);
    color: var(--body);
    font-family: var(--heading);
    font-size: 0.88rem;
    font-weight: 700;
    border-radius: 50px;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-pill-ghost:hover { border-color: var(--accent); color: var(--accent); }

  /* ══ PLATFORMS ══ */
  .platforms {
    background: var(--surface);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 1.2rem 0;
  }

  .platforms-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .platforms-label {
    font-family: var(--heading);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }

  .platforms-list {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .platform-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.42rem 1rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--rule);
    border-radius: 50px;
    font-size: 0.78rem;
    font-family: var(--heading);
    font-weight: 700;
    color: var(--muted);
    transition: border-color 0.2s, color 0.2s;
  }

  .platform-badge:hover { border-color: var(--accent); color: #fff; }

  /* ══ ABOUT ══ */
  .about-section {
    padding: 6rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .about-img-wrap {
    position: relative;
  }

  .about-img {
    width: 100%;
    aspect-ratio: 4/5;
    background-size: cover;
    background-position: center;
    border-radius: 12px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.45);
  }

  .about-heading {
    font-family: var(--heading);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 1.2rem;
  }

  .about-desc {
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 0.8rem;
  }

  /* ══ LATEST EPISODES ══ */
  .episodes-section {
    padding: 5rem 0;
    background: var(--surface);
    border-bottom: 1px solid var(--rule);
  }

  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-family: var(--heading);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 900;
    letter-spacing: -0.025em;
    color: #fff;
  }

  .all-link {
    font-family: var(--heading);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--accent);
    transition: opacity 0.2s;
    padding-bottom: 0.15rem;
  }

  .all-link:hover { opacity: 0.75; }

  .ep-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .ep-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--rule);
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
  }

  .ep-card:hover {
    border-color: rgba(238,53,158,0.4);
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.35);
  }

  .ep-card-thumb {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .ep-card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .ep-card:hover .ep-card-thumb img { transform: scale(1.05); }

  .ep-badge {
    position: absolute;
    top: 0.65rem;
    left: 0.65rem;
    background: rgba(238,53,158,0.9);
    color: #fff;
    font-family: var(--heading);
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.55rem;
    border-radius: 50px;
    text-transform: uppercase;
  }

  .ep-card-body {
    padding: 1rem 1.1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    flex: 1;
  }

  .ep-card-title {
    font-family: var(--heading);
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--body);
    transition: color 0.18s;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ep-card:hover .ep-card-title { color: #fff; }

  .ep-card-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.66rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  /* ══ BLOG ══ */
  .blog-section {
    padding: 5rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    border-radius: 8px;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--rule);
    transition: border-color 0.25s, transform 0.25s;
  }

  .blog-card:hover {
    border-color: rgba(238,53,158,0.4);
    transform: translateY(-3px);
  }

  .blog-card-thumb {
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .blog-card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .blog-card:hover .blog-card-thumb img { transform: scale(1.05); }

  .blog-card-body {
    padding: 1.2rem 1.3rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .blog-card-date {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .blog-card-title {
    font-family: var(--heading);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--body);
    transition: color 0.18s;
  }

  .blog-card:hover .blog-card-title { color: var(--accent); }

  .blog-card-desc {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ══ EPISODE LIST ══ */
  .list-section {
    padding-bottom: 5rem;
  }

  .list-header-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-top: 1px solid var(--rule);
    padding-top: 2rem;
    margin-bottom: 0;
  }

  /* ══ RESPONSIVE ══ */
  @media (max-width: 900px) {
    .about-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .about-img-wrap { max-width: 440px; }
  }

  @media (max-width: 768px) {
    .ep-cards-grid { grid-template-columns: 1fr 1fr; }
    .ep-cards-grid .ep-card:last-child { display: none; }
    .blog-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .ep-cards-grid { grid-template-columns: 1fr; }
    .ep-cards-grid .ep-card:last-child { display: flex; }
    .platforms-inner { gap: 1rem; }
  }
</style>
